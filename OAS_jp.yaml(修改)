openapi: 3.0.0
info:
  title: 設備管理システム API
  description: 部門内設備管理システムのAPIドキュメント、設備管理、権限管理、検査表管理などの機能を含む
  version: 1.0.0
  contact:
    name: システム管理者
    email: admin@company.com

servers:
  - url: http://localhost:8080/api
    description: ローカル開発環境
  - url: https://api.equipment.company.com/api
    description: 本番環境

tags:
  - name: 認証管理
    description: ユーザーログイン認証、ログアウト、パスワード管理
  - name: 管理者管理
    description: 管理者の追加・削除・編集・検索操作
  - name: ユーザー管理
    description: 設備利用ユーザー管理
  - name: 設備管理
    description: 設備情報管理
  - name: ファイル管理
    description: Excelファイルのアップロード・ダウンロード
  - name: 設備権限管理
    description: 設備利用権限管理
  - name: 検査表管理
    description: 設備検査表管理
  - name: 抜き取り検査
    description: 抜き取り検査管理
  - name: 非抜き取り検査
    description: 非抜き取り検査管理
  - name: 月次検査報告
    description: 月次検査報告管理
  - name: 辞書管理
    description: システム辞書データ管理

paths:
  # 認証管理
  /auth/login:
    post:
      tags:
        - 認証管理
      summary: ユーザーログイン
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                username:
                  type: string
                  description: ユーザー名
                password:
                  type: string
                  description: パスワード
      responses:
        "200":
          description: ログイン成功、JWTトークンを返す
          content:
            application/json:
              schema:
                type: object
                properties:
                  token:
                    type: string
                    description: JWTトークン
        "401":
          description: ログイン失敗、ユーザー名またはパスワードが間違っています
  /auth/logout:
    post:
      tags:
        - 認証管理
      summary: ユーザーログアウト
      responses:
        "200":
          description: ログアウト成功
        "401":
          description: 未ログインまたはトークン無効
  /auth/change-password:
    post:
      tags:
        - 認証管理
      summary: パスワード変更
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                oldPassword:
                  type: string
                  description: 旧パスワード
                newPassword:
                  type: string
                  description: 新パスワード
      responses:
        "200":
          description: パスワード変更成功
        "400":
          description: 旧パスワードが間違っているか、新パスワードが要件を満たしていません
        "401":
          description: 未ログインまたはトークン無効
  # 管理者管理
  /admins:
    get:
      tags:
        - 管理者管理
      summary: 管理者リスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: 管理者リスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: 管理者総数
                  admins:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: 管理者ID
                        username:
                          type: string
                          description: 管理者ユーザー名
                        email:
                          type: string
                          description: 管理者メールアドレス
    post:
      tags:
        - 管理者管理
      summary: 新規管理者作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                username:
                  type: string
                  description: 管理者ユーザー名
                password:
                  type: string
                  description: 管理者パスワード
                email:
                  type: string
                  description: 管理者メールアドレス
      responses:
        "201":
          description: 管理者作成成功
        "400":
          description: リクエストパラメータエラー
  /admins/{adminId}:
    put:
      tags:
        - 管理者管理
      summary: 管理者情報更新
      parameters:
        - in: path
          name: adminId
          required: true
          schema:
            type: integer
          description: 管理者ID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  description: 管理者メールアドレス
      responses:
        "200":
          description: 管理者情報更新成功
        "400":
          description: リクエストパラメータエラー
        "404":
          description: 管理者が見つかりません
    delete:
      tags:
        - 管理者管理
      summary: 管理者削除
      parameters:
        - in: path
          name: adminId
          required: true
          schema:
            type: integer
          description: 管理者ID
      responses:
        "200":
          description: 管理者削除成功
        "404":
          description: 管理者が見つかりません
  # ユーザー管理
  /users:
    get:
      tags:
        - ユーザー管理
      summary: ユーザーリスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: ユーザーリスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: ユーザー総数
                  users:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: ユーザーID
                        username:
                          type: string
                          description: ユーザー名
                        email:
                          type: string
                          description: ユーザーメールアドレス
    post:
      tags:
        - ユーザー管理
      summary: 新規ユーザー作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                username:
                  type: string
                  description: ユーザー名
                password:
                  type: string
                  description: ユーザーパスワード
                email:
                  type: string
                  description: ユーザーメールアドレス
      responses:
        "201":
          description: ユーザー作成成功
        "400":
          description: リクエストパラメータエラー
  /users/{userId}:
    put:
      tags:
        - ユーザー管理
      summary: ユーザー情報更新
      parameters:
        - in: path
          name: userId
          required: true
          schema:
            type: integer
          description: ユーザーID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  description: ユーザーメールアドレス
      responses:
        "200":
          description: ユーザー情報更新成功
        "400":
          description: リクエストパラメータエラー
        "404":
          description: ユーザーが見つかりません
    delete:
      tags:
        - ユーザー管理
      summary: ユーザー削除
      parameters:
        - in: path
          name: userId
          required: true
          schema:
            type: integer
          description: ユーザーID
      responses:
        "200":
          description: ユーザー削除成功
        "404":
          description: ユーザーが見つかりません
  # 設備管理
  /devices:
    get:
      tags:
        - 設備管理
      summary: 設備リスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: 設備リスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: 設備総数
                  devices:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: 設備ID
                        name:
                          type: string
                          description: 設備名
                        model:
                          type: string
                          description: 設備モデル
                        serialNumber:
                          type: string
                          description: 設備シリアル番号
    post:
      tags:
        - 設備管理
      summary: 新規設備作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                name:
                  type: string
                  description: 設備名
                model:
                  type: string
                  description: 設備モデル
                serialNumber:
                  type: string
                  description: 設備シリアル番号
      responses:
        "201":
          description: 設備作成成功
        "400":
          description: リクエストパラメータエラー
  /devices/{deviceId}:
    put:
      tags:
        - 設備管理
      summary: 設備情報更新
      parameters:
        - in: path
          name: deviceId
          required: true
          schema:
            type: integer
          description: 設備ID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                name:
                  type: string
                  description: 設備名
                model:
                  type: string
                  description: 設備モデル
                serialNumber:
                  type: string
                  description: 設備シリアル番号
      responses:
        "200":
          description: 設備情報更新成功
        "400":
          description: リクエストパラメータエラー
        "404":
          description: 設備が見つかりません
    delete:
      tags:
        - 設備管理
      summary: 設備削除
      parameters:
        - in: path
          name: deviceId
          required: true
          schema:
            type: integer
          description: 設備ID
      responses:
        "200":
          description: 設備削除成功
        "404":
          description: 設備が見つかりません
          content:
            application/json:
              schema:
                type: object
                properties:
                  message:
                    type: string
                    description: エラーメッセージ
                  code:
                    type: integer
                    description: エラーコード
  # ファイル管理
  /files/upload:
    post:
      tags:
        - ファイル管理
      summary: Excelファイルアップロード
      requestBody:
        required: true
        content:
          multipart/form-data:
            schema:
              type: object
              properties:
                file:
                  type: string
                  format: binary
                  description: Excelファイル
      responses:
        "200":
          description: ファイルアップロード成功
        "400":
          description: ファイル形式エラーまたはアップロード失敗
  /files/download/{fileId}:
    get:
      tags:
        - ファイル管理
      summary: Excelファイルダウンロード
      parameters:
        - in: path
          name: fileId
          required: true
          schema:
            type: string
          description: ファイルID
      responses:
        "200":
          description: ファイルダウンロード成功
          content:
            application/vnd.openxmlformats-officedocument.spreadsheetml.sheet:
              schema:
                type: string
                format: binary
        "404":
          description: ファイルが見つかりません
  # 設備権限管理
  /device-permissions:
    get:
      tags:
        - 設備権限管理
      summary: 設備権限リスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: 設備権限リスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: 設備権限総数
                  permissions:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: 権限ID
                        deviceId:
                          type: integer
                          description: 設備ID
                        userId:
                          type: integer
                          description: ユーザーID
                        accessLevel:
                          type: string
                          description: アクセスレベル
    post:
      tags:
        - 設備権限管理
      summary: 設備権限作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                deviceId:
                  type: integer
                  description: 設備ID
                userId:
                  type: integer
                  description: ユーザーID
                accessLevel:
                  type: string
                  description: アクセスレベル
      responses:
        "201":
          description: 設備権限作成成功
        "400":
          description: リクエストパラメータエラー
  /device-permissions/{permissionId}:
    put:
      tags:
        - 設備権限管理
      summary: 設備権限更新
      parameters:
        - in: path
          name: permissionId
          required: true
          schema:
            type: integer
          description: 権限ID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                accessLevel:
                  type: string
                  description: アクセスレベル
      responses:
        "200":
          description: 設備権限更新成功
        "400":
          description: リクエストパラメータエラー
        "404":
          description: 設備権限が見つかりません
    delete:
      tags:
        - 設備権限管理
      summary: 設備権限削除
      parameters:
        - in: path
          name: permissionId
          required: true
          schema:
            type: integer
          description: 権限ID
      responses:
        "200":
          description: 設備権限削除成功
        "404":
          description: 設備権限が見つかりません
  # 検査表管理
  /checklists:
    get:
      tags:
        - 検査表管理
      summary: 検査表リスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: 検査表リスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: 検査表総数
                  checklists:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: 検査表ID
                        name:
                          type: string
                          description: 検査表名
                        description:
                          type: string
                          description: 検査表説明
    post:
      tags:
        - 検査表管理
      summary: 新規検査表作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                name:
                  type: string
                  description: 検査表名
                description:
                  type: string
                  description: 検査表説明
      responses:
        "201":
          description: 検査表作成成功
        "400":
          description: リクエストパラメータエラー
  /checklists/{checklistId}:
    put:
      tags:
        - 検査表管理
      summary: 検査表情報更新
      parameters:
        - in: path
          name: checklistId
          required: true
          schema:
            type: integer
          description: 検査表ID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                name:
                  type: string
                  description: 検査表名
                description:
                  type: string
                  description: 検査表説明
      responses:
        "200":
          description: 検査表情報更新成功
        "400":
          description: リクエストパラメータエラー
        "404":
          description: 検査表が見つかりません
    delete:
      tags:
        - 検査表管理
      summary: 検査表削除
      parameters:
        - in: path
          name: checklistId
          required: true
          schema:
            type: integer
          description: 検査表ID
      responses:
        "200":
          description: 検査表削除成功
        "404":
          description: 検査表が見つかりません
  # 抜き取り検査
  /pull-checks:
    get:
      tags:
        - 抜き取り検査
      summary: 抜き取り検査リスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: 抜き取り検査リスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: 抜き取り検査総数
                  pullChecks:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: 抜き取り検査ID
                        deviceId:
                          type: integer
                          description: 設備ID
                        checklistId:
                          type: integer
                          description: 検査表ID
                        status:
                          type: string
                          description: 検査ステータス
    post:
      tags:
        - 抜き取り検査
      summary: 新規抜き取り検査作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                deviceId:
                  type: integer
                  description: 設備ID
                checklistId:
                  type: integer
                  description: 検査表ID
                status:
                  type: string
                  description: 検査ステータス
      responses:
        "201":
          description: 抜き取り検査作成成功
        "400":
          description: リクエストパラメータエラー
  /pull-checks/{pullCheckId}:
    put:
      tags:
        - 抜き取り検査
      summary: 抜き取り検査情報更新
      parameters:
        - in: path
          name: pullCheckId
          required: true
          schema:
            type: integer
          description: 抜き取り検査ID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                status:
                  type: string
                  description: 検査ステータス
      responses:
        "200":
          description: 抜き取り検査情報更新成功
        "400":
          description: リクエストパラメータエラー
        "404":
          description: 抜き取り検査が見つかりません
    delete:
      tags:
        - 抜き取り検査
      summary: 抜き取り検査削除
      parameters:
        - in: path
          name: pullCheckId
          required: true
          schema:
            type: integer
          description: 抜き取り検査ID
      responses:
        "200":
          description: 抜き取り検査削除成功
        "404":
          description: 抜き取り検査が見つかりません
  # 非抜き取り検査
  /non-pull-checks:
    get:
      tags:
        - 非抜き取り検査
      summary: 非抜き取り検査リスト取得
      parameters:
        - in: query
          name: page
          schema:
            type: integer
            default: 1
          description: ページ番号
        - in: query
          name: pageSize
          schema:
            type: integer
            default: 10
          description: ページあたりの件数
      responses:
        "200":
          description: 非抜き取り検査リスト取得成功
          content:
            application/json:
              schema:
                type: object
                properties:
                  total:
                    type: integer
                    description: 非抜き取り検査総数
                  nonPullChecks:
                    type: array
                    items:
                      type: object
                      properties:
                        id:
                          type: integer
                          description: 非抜き取り検査ID
                        deviceId:
                          type: integer
                          description: 設備ID
                        checklistId:
                          type: integer
                          description: 検査表ID
                        status:
                          type: string
                          description: 検査ステータス
    post:
      tags:
        - 非抜き取り検査
      summary: 新規非抜き取り検査作成
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                deviceId:
                  type: integer
                  description: 設備ID
                checklistId:
                  type: integer
                  description: 検査表ID
                status:
                  type: string
                  description: 検査ステータス
      responses:
        "201":
          description: 非抜き取り検査作成成功
        "400":
          description: リクエストパラメータエラー
  /non-pull-checks/{nonPullCheckId}:
    put:
      tags:
        - 非抜き取り検査
      summary: 非抜き取り検査情報更新
      parameters:
        - in: path
          name: nonPullCheckId
          required: true
          schema:
            type: integer
          description: 非抜き取り検査ID
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                status:
                  type: string
